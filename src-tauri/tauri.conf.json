{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgentWatch",
  "version": "0.2.10",
  "identifier": "app.agentwatch.desktop",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://127.0.0.1:8765",
    "frontendDist": "../static"
  },
  "app": {
    "windows": [
      {
        "title": "AgentWatch",
        "label": "main",
        "url": "http://127.0.0.1:8765",
        "visible": false,
        "width": 1280,
        "height": 820,
        "minWidth": 940,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "publisher": "AgentWatch",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "Copyright (c) AgentWatch",
    "license": "MIT OR Apache-2.0",
    "category": "DeveloperTool",
    "shortDescription": "Monitor local LLM agents",
    "longDescription": "AgentWatch monitors local LLM and coding-agent processes, logs activity, and exposes a LAN dashboard.",
    "useLocalToolsDir": true,
    "windows": {
      "allowDowngrades": false,
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "startMenuFolder": "AgentWatch"
      }
    },
    "linux": {
      "deb": {
        "section": "utils",
        "priority": "optional"
      },
      "rpm": {
        "release": "1"
      }
    },
    "macOS": {
      "bundleName": "AgentWatch",
      "hardenedRuntime": true,
      "signingIdentity": "-",
      "minimumSystemVersion": "11.0",
      "infoPlist": "Info.plist"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZGQzExNTNCRUU5NTlFODAKUldTQW5wWHVPeFhCLzYxN2Yrcm9MZm5tQTE2bzF1SXhPelJ6ZzdTd01zRmVOdDVsWlFqVWZudGEK",
      "endpoints": [
        "https://github.com/donghwan0206/agentwatch/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
